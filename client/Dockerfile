# Build React app (env vars are baked in at build time)
FROM node:22-alpine AS build
WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm ci

COPY . .

ARG REACT_APP_SERVER_URL=http://139.59.6.209
ENV REACT_APP_SERVER_URL=$REACT_APP_SERVER_URL

ARG REACT_APP_INTRO_VIDEO_URL=https://www.youtube.com/watch?v=vciPv_GGQ0E
ENV REACT_APP_INTRO_VIDEO_URL=$REACT_APP_INTRO_VIDEO_URL

ARG REACT_APP_WHATSAPP_NUMBER=
ENV REACT_APP_WHATSAPP_NUMBER=$REACT_APP_WHATSAPP_NUMBER

ARG REACT_APP_WHATSAPP_COMMUNITY_LINK=
ENV REACT_APP_WHATSAPP_COMMUNITY_LINK=$REACT_APP_WHATSAPP_COMMUNITY_LINK

ARG REACT_APP_EMAIL=
ENV REACT_APP_EMAIL=$REACT_APP_EMAIL

ARG REACT_APP_PHONE=
ENV REACT_APP_PHONE=$REACT_APP_PHONE

ARG REACT_APP_ADDRESS=
ENV REACT_APP_ADDRESS=$REACT_APP_ADDRESS

ARG REACT_APP_GOOGLE_MAPS_LINK=
ENV REACT_APP_GOOGLE_MAPS_LINK=$REACT_APP_GOOGLE_MAPS_LINK

ARG REACT_APP_GOOGLE_MAPS_EMBED_URL=
ENV REACT_APP_GOOGLE_MAPS_EMBED_URL=$REACT_APP_GOOGLE_MAPS_EMBED_URL

ARG REACT_APP_INSTAGRAM_LINK=
ENV REACT_APP_INSTAGRAM_LINK=$REACT_APP_INSTAGRAM_LINK

ARG REACT_APP_FACEBOOK_LINK=
ENV REACT_APP_FACEBOOK_LINK=$REACT_APP_FACEBOOK_LINK

ARG REACT_APP_X_LINK=
ENV REACT_APP_X_LINK=$REACT_APP_X_LINK

ARG REACT_APP_LINKEDIN_LINK=
ENV REACT_APP_LINKEDIN_LINK=$REACT_APP_LINKEDIN_LINK

ARG REACT_APP_YOUTUBE_LINK=
ENV REACT_APP_YOUTUBE_LINK=$REACT_APP_YOUTUBE_LINK

RUN npm run build

FROM nginx:1.27-alpine
COPY --from=build /app/build /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80

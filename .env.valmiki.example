# Copy this file to .env.valmiki and adjust values for your droplet.
# This compose deployment is isolated from gurukulamhub.org and serves:
# - Valmiki client at http://<droplet-ip>:4000
# - Valmiki API at http://<droplet-ip>:5000

CLIENT_URL=http://139.59.6.209:4000
REACT_APP_SERVER_URL=http://139.59.6.209:5000
MONGO_URI=mongodb://mongo:27017/valmiki
ADMIN_JWT_SECRET=change-me-long-random-secret
MAX_UPLOAD_MB=25

# Optional storage settings (leave empty if not using uploads yet)
S3_REGION=
S3_SPACE_NAME=
S3_ACCESS_KEY_ID=
S3_ACCESS_KEY_SECRET=
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=

# Optional client content/contact links
REACT_APP_INTRO_VIDEO_URL=https://www.youtube.com/watch?v=vciPv_GGQ0E
REACT_APP_WHATSAPP_NUMBER=
REACT_APP_WHATSAPP_COMMUNITY_LINK=
REACT_APP_EMAIL=
REACT_APP_PHONE=
REACT_APP_ADDRESS=
REACT_APP_GOOGLE_MAPS_LINK=
REACT_APP_GOOGLE_MAPS_EMBED_URL=
REACT_APP_INSTAGRAM_LINK=
REACT_APP_FACEBOOK_LINK=
REACT_APP_X_LINK=
REACT_APP_LINKEDIN_LINK=
REACT_APP_YOUTUBE_LINK=
